        "operation": "executeQuery",
        "query": "SELECT * FROM {{ $(\"Execute Workflow Trigger\").first().json.schema_name || \"public\" }}.cancelar_agendamento($1::bigint, $2::varchar, NULLIF(TRIM($3::text), ''));",
        "options": {
          "queryReplacement": "={{ [$json.appointment_id, $json.patient_phone, $json.reason] }}"
        }
