    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM {{ $(\"Trigger\").first().json.schema_name || \"public\" }}.obter_agendamentos_paciente($1::varchar, NULLIF(TRIM($2::text), ''), 5);",
        "options": {
          "queryReplacement": "={{ [$json.patient_phone || $json.telefone_paciente, $json.status || ' '] }}"
        }
      },
